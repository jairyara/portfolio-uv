---
const year = new Date().getFullYear();

const links = [
  { href: 'https://github.com/tu-usuario', label: 'GitHub' },
  { href: 'https://linkedin.com/in/tu-usuario', label: 'LinkedIn' },
  { href: 'mailto:hola@jairyara.dev', label: 'Email' },
];
---

<footer class="border-t border-white/5 py-10 px-6">
  <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
    <div class="flex items-center gap-2 font-display font-bold">
      <span class="w-6 h-6 rounded bg-acid flex items-center justify-center text-ink text-xs font-mono">JY</span>
      <span class="text-white/60 text-sm">© {year} Jair Yara</span>
    </div>

    <div class="flex items-center gap-6">
      {links.map(link => (
        <a 
          href={link.href} 
          target="_blank" 
          rel="noopener noreferrer"
          class="text-sm text-slate-soft hover:text-acid transition-colors font-mono"
        >
          {link.label}
        </a>
      ))}
    </div>

    <p class="text-xs text-white/20 font-mono">
      Built with Astro + Tailwind · Bogotá, CO
    </p>
  </div>
</footer>
