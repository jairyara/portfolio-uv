---
const projects = [
  {
    title: 'Corporación Volver a la Gente',
    type: 'ONG Website',
    desc: 'Sitio web institucional para ONG colombiana. Astro + Tailwind con Directus como CMS headless, deploy en Dokploy. SEO optimizado y rendimiento 95+ en Lighthouse.',
    tags: ['Astro', 'Directus', 'Tailwind', 'Dokploy'],
    highlight: true,
    status: 'En producción',
    link: '#',
  },
  {
    title: 'Phoenix Group',
    type: 'Consultora de Ciberseguridad',
    desc: 'Website B2B para consultora de ciberseguridad orientada al mercado latinoamericano. Schema.org, Search Console, reCAPTCHA y Cloudflare Pages.',
    tags: ['Astro', 'Cloudflare Pages', 'SEO', 'Schema.org'],
    highlight: true,
    status: 'En producción',
    link: '#',
  },
  {
    title: 'Calculadora de Cuotas',
    type: 'App Android',
    desc: 'Aplicación móvil para calcular cuotas de tarjeta de crédito con distintas tasas. Más de 150 USD/mes en ingresos pasivos por AdMob.',
    tags: ['Android', 'AdMob', 'Play Store'],
    highlight: false,
    status: 'Play Store',
    link: '#',
  },
  {
    title: 'GPS Offline Coordinates',
    type: 'App Android',
    desc: 'App de coordenadas GPS que funciona completamente offline. Usada por topógrafos e interventores en campo sin conectividad.',
    tags: ['Android', 'GPS', 'Offline', 'Play Store'],
    highlight: false,
    status: 'Play Store',
    link: '#',
  },
  {
    title: 'Plataforma SaaS Interventoría',
    type: 'SaaS — En desarrollo',
    desc: 'Sistema para inspectores de construcción: generación de actas, control de mezcladoras, cartillas de acero. Basado en 5 años de experiencia en campo.',
    tags: ['Laravel', 'SaaS', 'Construcción'],
    highlight: false,
    status: 'En desarrollo',
    link: null,
  },
  {
    title: 'WA Contact-Free Chat',
    type: 'App Android',
    desc: 'Herramienta para iniciar conversaciones en WhatsApp sin necesidad de guardar el contacto. Monetizada con AdMob en Play Store.',
    tags: ['Android', 'WhatsApp API', 'AdMob'],
    highlight: false,
    status: 'Play Store',
    link: '#',
  },
];
---

<section id="proyectos" class="py-28 px-6 relative">
  <!-- Background accent -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden">
    <div class="absolute left-0 top-1/2 w-80 h-80 bg-acid/4 rounded-full blur-[100px]"></div>
  </div>

  <div class="max-w-6xl mx-auto">
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-14 gap-4">
      <div>
        <span class="section-label">Proyectos</span>
        <h2 class="font-display text-4xl md:text-5xl font-bold text-white leading-tight mt-2">
          Cosas que he<br /><span class="text-acid">construido</span>
        </h2>
      </div>
      <p class="text-slate-soft max-w-xs text-sm">
        Desde apps móviles con revenue pasivo hasta plataformas web para ONG y consultoras.
      </p>
    </div>

    <!-- Featured projects (2 col) -->
    <div class="grid md:grid-cols-2 gap-6 mb-6">
      {projects.filter(p => p.highlight).map(project => (
        <div class="card-glass p-7 rounded-2xl border-glow group hover:border-acid/20 transition-all duration-300 flex flex-col">
          <div class="flex items-start justify-between mb-4">
            <span class="tag text-acid border-acid/20 bg-acid/5">{project.type}</span>
            <span class={`text-xs font-mono px-2 py-0.5 rounded-full ${
              project.status === 'En producción' 
                ? 'bg-emerald-500/10 text-emerald-400 border border-emerald-500/20' 
                : 'bg-yellow-500/10 text-yellow-400 border border-yellow-500/20'
            }`}>{project.status}</span>
          </div>

          <h3 class="font-display font-bold text-xl text-white mb-2 group-hover:text-acid transition-colors">
            {project.title}
          </h3>
          <p class="text-slate-soft text-sm leading-relaxed flex-1 mb-5">{project.desc}</p>

          <div class="flex flex-wrap gap-2 mb-5">
            {project.tags.map(tag => <span class="tag">{tag}</span>)}
          </div>

          {project.link && (
            <a href={project.link} target="_blank" class="text-acid font-mono text-sm flex items-center gap-2 hover:gap-3 transition-all">
              Ver proyecto
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
              </svg>
            </a>
          )}
        </div>
      ))}
    </div>

    <!-- Other projects (3 col) -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {projects.filter(p => !p.highlight).map(project => (
        <div class="card-glass p-5 rounded-2xl group hover:border-white/10 transition-all duration-300 flex flex-col">
          <div class="flex items-center justify-between mb-3">
            <span class="text-white/30 text-xs font-mono">{project.type}</span>
            <span class={`text-xs font-mono px-2 py-0.5 rounded-full ${
              project.status === 'Play Store'
                ? 'bg-blue-500/10 text-blue-400 border border-blue-500/20'
                : project.status === 'En desarrollo'
                ? 'bg-orange-500/10 text-orange-400 border border-orange-500/20'
                : 'bg-emerald-500/10 text-emerald-400 border border-emerald-500/20'
            }`}>{project.status}</span>
          </div>

          <h3 class="font-display font-semibold text-white mb-2 group-hover:text-acid transition-colors">
            {project.title}
          </h3>
          <p class="text-slate-soft text-xs leading-relaxed flex-1 mb-4">{project.desc}</p>

          <div class="flex flex-wrap gap-1.5">
            {project.tags.map(tag => <span class="tag text-xs">{tag}</span>)}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
