---
const stats = [
  { value: '5+', label: 'años de experiencia' },
  { value: '20+', label: 'proyectos entregados' },
  { value: '3', label: 'apps en Play Store' },
  { value: '∞', label: 'líneas de código' },
];

const timeline = [
  {
    year: '2024–hoy',
    role: 'Dev Independiente + Coordinador Semillero',
    desc: 'Desarrollando productos SaaS y plataformas web para PYMEs colombianas. Coordinando el Semillero de Ciberseguridad Sapientiam en ETITC.',
  },
  {
    year: '2022–2024',
    role: 'Desarrollador & Especialista en Seguridad',
    desc: 'Proyectos de Laravel, WooCommerce y e-commerce con foco en seguridad y rendimiento. VPS administrado con Dokploy.',
  },
  {
    year: '2019–2022',
    role: 'Interventor de Obra / Construcción',
    desc: 'Cinco años en interventoría de proyectos de construcción. Gestión de actas, materiales y auditoría técnica en campo.',
  },
];
---

<section id="sobre-mi" class="py-28 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="grid md:grid-cols-2 gap-16 items-start">
      <!-- Left: text -->
      <div class="space-y-8">
        <div>
          <span class="section-label">Sobre mí</span>
          <h2 class="font-display text-4xl md:text-5xl font-bold text-white leading-tight mt-2">
            Construyo puentes entre <span class="text-acid">código y negocio</span>
          </h2>
        </div>

        <div class="space-y-4 text-slate-soft leading-relaxed">
          <p>
            Soy desarrollador Full Stack y especialista en ciberseguridad con base en Bogotá. 
            Llevo años construyendo productos digitales para empresas que quieren crecer sin descuidar su seguridad.
          </p>
          <p>
            Vengo de un background inusual: antes de dedicarme al software, fui interventor de obras de construcción por cinco años. 
            Eso me enseñó que un sistema —ya sea de concreto o de código— tiene que ser sólido desde los cimientos.
          </p>
          <p>
            Hoy combino desarrollo (Laravel, Astro, WooCommerce) con una visión de seguridad que pocas agencias tienen. 
            También soy coordinador del <strong class="text-white">Semillero Sapientiam</strong>, un grupo de investigación en ciberseguridad 
            que dirijo en la ETITC con más de 17 estudiantes activos.
          </p>
        </div>

        <div class="flex gap-4 flex-wrap">
          <a href="/#proyectos" class="btn-primary">Ver mis proyectos</a>
          <a href="/cv.pdf" download class="btn-ghost">
            Descargar CV
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v12m0 0l-4-4m4 4l4-4M4 20h16"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Right: stats + timeline -->
      <div class="space-y-8">
        <!-- Stats grid -->
        <div class="grid grid-cols-2 gap-4">
          {stats.map(stat => (
            <div class="card-glass p-5 rounded-2xl text-center">
              <div class="font-display text-3xl font-extrabold text-acid">{stat.value}</div>
              <div class="text-xs text-slate-soft mt-1 font-mono">{stat.label}</div>
            </div>
          ))}
        </div>

        <!-- Timeline -->
        <div class="space-y-4">
          <h3 class="font-display font-bold text-white text-sm uppercase tracking-wider opacity-50">Trayectoria</h3>
          {timeline.map((item, i) => (
            <div class="flex gap-4">
              <div class="flex flex-col items-center gap-1 pt-1">
                <div class="w-2 h-2 rounded-full bg-acid shrink-0"></div>
                {i < timeline.length - 1 && <div class="w-px flex-1 bg-white/10 min-h-[40px]"></div>}
              </div>
              <div class="pb-4">
                <span class="font-mono text-xs text-acid">{item.year}</span>
                <h4 class="font-display font-semibold text-white text-sm mt-1">{item.role}</h4>
                <p class="text-slate-soft text-sm mt-1 leading-relaxed">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
