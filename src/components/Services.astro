---
const services = [
  {
    icon: '⚡',
    title: 'Desarrollo Web',
    desc: 'Sitios institucionales, landing pages y e-commerce con Astro, Laravel o WordPress/WooCommerce. Rápidos, optimizados para SEO y listos para escalar.',
    items: ['Astro / WordPress / Laravel', 'WooCommerce y tiendas online', 'Mantenimiento mensual', 'Hosting gestionado en VPS'],
    price: 'Desde $800 USD',
  },
  {
    icon: '🛡️',
    title: 'Ciberseguridad',
    desc: 'Auditorías de seguridad, análisis de vulnerabilidades y consultoría para empresas que quieren proteger sus activos digitales sin complicaciones.',
    items: ['Pentesting web y de red', 'Auditoría de infraestructura', 'Implementación Zero Trust', 'OSINT y reconocimiento'],
    price: 'Desde $500 USD',
  },
  {
    icon: '🚀',
    title: 'Productos SaaS',
    desc: 'Diseño y desarrollo de herramientas web a medida. Desde el MVP hasta el lanzamiento con monetización, métricas y arquitectura pensada para crecer.',
    items: ['Arquitectura backend (Laravel / Node)', 'Integraciones y APIs', 'Pasarelas de pago (PSE, Stripe)', 'Panel de administración'],
    price: 'A consultar',
  },
  {
    icon: '🖥️',
    title: 'Infraestructura y Hosting',
    desc: 'Administración de VPS, configuración de servidores Linux, CI/CD y despliegue de aplicaciones. Tu infraestructura lista y segura en horas.',
    items: ['Hosting web y WooCommerce', 'Configuración de Cloudflare', 'Deploy con Dokploy / Docker', 'Monitoreo y backups'],
    price: 'Desde $30 USD/mes',
  },
];
---

<section id="servicios" class="py-28 px-6 relative">
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute right-0 top-1/2 w-72 h-72 bg-acid/4 rounded-full blur-[80px]"></div>
  </div>

  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-14">
      <span class="section-label justify-center">Servicios</span>
      <h2 class="font-display text-4xl md:text-5xl font-bold text-white mt-2 leading-tight">
        ¿En qué puedo <span class="text-acid">ayudarte?</span>
      </h2>
      <p class="text-slate-soft mt-4 max-w-xl mx-auto">
        Trabajo directamente con fundadores, emprendedores y PYMEs colombianas que necesitan 
        un desarrollador que entienda tanto el código como el negocio.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-6">
      {services.map((service, i) => (
        <div class={`card-glass p-7 rounded-2xl flex flex-col gap-5 hover:border-acid/15 transition-all duration-300 group ${i === 0 ? 'border-glow' : ''}`}>
          <div class="flex items-start justify-between">
            <div class="w-12 h-12 rounded-xl bg-acid/10 border border-acid/15 flex items-center justify-center text-2xl">
              {service.icon}
            </div>
            <span class="font-mono text-xs text-acid border border-acid/20 px-3 py-1 rounded-full bg-acid/5">
              {service.price}
            </span>
          </div>

          <div>
            <h3 class="font-display font-bold text-xl text-white group-hover:text-acid transition-colors mb-2">
              {service.title}
            </h3>
            <p class="text-slate-soft text-sm leading-relaxed">{service.desc}</p>
          </div>

          <ul class="space-y-2 mt-auto">
            {service.items.map(item => (
              <li class="flex items-center gap-2 text-sm text-white/60">
                <span class="w-1 h-1 rounded-full bg-acid shrink-0"></span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- CTA banner -->
    <div class="mt-10 card-glass rounded-2xl p-8 flex flex-col md:flex-row items-center justify-between gap-6 border-glow">
      <div>
        <h3 class="font-display font-bold text-white text-xl mb-1">¿Tienes un proyecto en mente?</h3>
        <p class="text-slate-soft text-sm">Cuéntame qué necesitas. Respondo en menos de 24 horas.</p>
      </div>
      <a href="/#contacto" class="btn-primary shrink-0">
        Solicitar cotización
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>
  </div>
</section>
