---
---

<section class="min-h-screen flex items-center pt-20 px-6 relative overflow-hidden">
  <!-- Decorative background elements -->
  <div class="absolute inset-0 pointer-events-none">
    <!-- Grid pattern -->
    <div class="absolute inset-0 opacity-[0.03]"
      style="background-image: linear-gradient(rgba(255,255,255,.15) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.15) 1px, transparent 1px); background-size: 60px 60px;">
    </div>
    <!-- Glow orbs -->
    <div class="absolute top-1/3 right-0 w-96 h-96 rounded-full bg-acid/5 blur-[120px]"></div>
    <div class="absolute bottom-0 left-1/4 w-64 h-64 rounded-full bg-acid/3 blur-[80px]"></div>
  </div>

  <div class="max-w-6xl mx-auto w-full grid md:grid-cols-2 gap-16 items-center py-16">
    <!-- Text content -->
    <div class="space-y-8 opacity-0 animate-fade-up" style="animation-fill-mode:forwards;">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-acid/10 border border-acid/20 text-acid text-xs font-mono">
        <span class="w-1.5 h-1.5 rounded-full bg-acid animate-pulse"></span>
        Disponible para proyectos
      </div>

      <!-- Headline -->
      <div>
        <h1 class="font-display text-5xl md:text-6xl lg:text-7xl font-extrabold leading-[1.05] tracking-tight">
          <span class="text-white">Dev.</span><br />
          <span class="text-white">Seguridad.</span><br />
          <span class="text-acid">Impacto.</span>
        </h1>
      </div>

      <!-- Bio -->
      <p class="text-slate-soft text-lg leading-relaxed max-w-lg">
        Soy <strong class="text-white font-medium">Jair Yara</strong>, desarrollador Full Stack y especialista en ciberseguridad desde Bogotá. 
        Construyo productos web robustos, plataformas seguras y sistemas que generan valor real para las empresas.
      </p>

      <!-- Tech stack inline -->
      <div class="flex flex-wrap gap-2">
        {['Laravel', 'Astro', 'WooCommerce', 'Linux', 'Zero Trust', 'OSINT'].map(tech => (
          <span class="tag">{tech}</span>
        ))}
      </div>

      <!-- CTAs -->
      <div class="flex flex-wrap gap-4">
        <a href="/#proyectos" class="btn-primary">
          Ver proyectos
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
        <a href="/#contacto" class="btn-ghost">Hablemos</a>
      </div>
    </div>

    <!-- Visual card -->
    <div class="hidden md:block opacity-0 animate-fade-up delay-3" style="animation-fill-mode:forwards;">
      <div class="relative">
        <!-- Terminal card -->
        <div class="card-glass p-6 rounded-2xl border-glow font-mono text-sm space-y-4 animate-float">
          <!-- Terminal header -->
          <div class="flex items-center gap-2 pb-3 border-b border-white/5">
            <span class="w-3 h-3 rounded-full bg-red-500/70"></span>
            <span class="w-3 h-3 rounded-full bg-yellow-500/70"></span>
            <span class="w-3 h-3 rounded-full bg-acid/70"></span>
            <span class="ml-2 text-white/20 text-xs">~/jair $</span>
          </div>
          
          <!-- Terminal output -->
          <div class="space-y-2 text-xs leading-relaxed">
            <div><span class="text-acid">❯</span> <span class="text-white/40">whoami</span></div>
            <div class="text-white pl-4">Jair Yara</div>
            
            <div class="mt-3"><span class="text-acid">❯</span> <span class="text-white/40">skills --list</span></div>
            <div class="pl-4 space-y-1 text-white/70">
              <div><span class="text-acid">✓</span> Full Stack: Laravel, Astro, React, PHP</div>
              <div><span class="text-acid">✓</span> Infra: Linux, VPS, Docker, CI/CD</div>
              <div><span class="text-acid">✓</span> Sec: Pentesting, OSINT, Zero Trust</div>
              <div><span class="text-acid">✓</span> Negocio: SaaS, WooCommerce, PYMEs</div>
            </div>

            <div class="mt-3"><span class="text-acid">❯</span> <span class="text-white/40">location</span></div>
            <div class="text-white pl-4">Bogotá, Colombia 🇨🇴</div>
            
            <div class="mt-3 flex items-center gap-1">
              <span class="text-acid">❯</span>
              <span class="text-white/40">status</span>
              <span class="cursor-blink"></span>
            </div>
          </div>
        </div>

        <!-- Floating badges -->
        <div class="absolute -top-4 -right-4 card-glass px-3 py-2 text-xs font-mono text-acid border-acid/20 rounded-xl">
          5+ años exp.
        </div>
        <div class="absolute -bottom-4 -left-4 card-glass px-3 py-2 text-xs font-mono text-white/60 rounded-xl">
          Bogotá · Remote ✓
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-white/20">
    <span class="text-xs font-mono">scroll</span>
    <div class="w-px h-8 bg-gradient-to-b from-white/20 to-transparent"></div>
  </div>
</section>
