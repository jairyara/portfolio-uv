---
---

<section id="contacto" class="py-28 px-6">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-14">
      <span class="section-label justify-center">Contacto</span>
      <h2 class="font-display text-4xl md:text-5xl font-bold text-white mt-2 leading-tight">
        Empecemos a <span class="text-acid">trabajar</span>
      </h2>
      <p class="text-slate-soft mt-4 max-w-lg mx-auto">
        ¿Tienes un proyecto? ¿Quieres una auditoría de seguridad? 
        Cuéntame qué necesitas y te respondo rápido.
      </p>
    </div>

    <div class="grid md:grid-cols-5 gap-8">
      <!-- Form -->
      <div class="md:col-span-3 card-glass p-7 rounded-2xl border-glow">
        <form id="contact-form" class="space-y-5">
          <!-- Honeypot - invisible para humanos -->
          <input type="text" name="website" style="display:none" tabindex="-1" autocomplete="off" />

          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label class="block text-xs font-mono mb-2 uppercase tracking-wider" style="color: var(--color-slate-soft)">Nombre</label>
              <input type="text" name="name" required placeholder="Tu nombre"
                     class="w-full border rounded-xl px-4 py-3 text-white text-sm focus:outline-none transition-colors"
                     style="background: rgba(255,255,255,0.05); border-color: rgba(255,255,255,0.10);" />
            </div>
            <div>
              <label class="block text-xs font-mono mb-2 uppercase tracking-wider" style="color: var(--color-slate-soft)">Email</label>
              <input type="email" name="email" required placeholder="tu@empresa.com"
                     class="w-full border rounded-xl px-4 py-3 text-white text-sm focus:outline-none transition-colors"
                     style="background: rgba(255,255,255,0.05); border-color: rgba(255,255,255,0.10);" />
            </div>
          </div>

          <div>
            <label class="block text-xs font-mono mb-2 uppercase tracking-wider" style="color: var(--color-slate-soft)">Servicio de interés</label>
            <select name="service"
                    class="w-full border rounded-xl px-4 py-3 text-sm focus:outline-none transition-colors"
                    style="background: rgba(255,255,255,0.05); border-color: rgba(255,255,255,0.10); color: rgba(255,255,255,0.7);">
              <option value="" style="background:#0A0A0F">Selecciona una opción</option>
              <option value="web" style="background:#0A0A0F">Desarrollo Web</option>
              <option value="cyber" style="background:#0A0A0F">Ciberseguridad</option>
              <option value="saas" style="background:#0A0A0F">Producto SaaS</option>
              <option value="infra" style="background:#0A0A0F">Infraestructura / Hosting</option>
              <option value="otro" style="background:#0A0A0F">Otro</option>
            </select>
          </div>

          <div>
            <label class="block text-xs font-mono mb-2 uppercase tracking-wider" style="color: var(--color-slate-soft)">Mensaje</label>
            <textarea name="message" rows="4" required placeholder="Cuéntame sobre tu proyecto..."
                      class="w-full border rounded-xl px-4 py-3 text-white text-sm focus:outline-none transition-colors resize-none"
                      style="background: rgba(255,255,255,0.05); border-color: rgba(255,255,255,0.10);"></textarea>
          </div>

          <!-- Feedback -->
          <div id="form-success" class="hidden rounded-xl px-4 py-3 text-sm"
               style="background: rgba(45,212,191,0.1); border: 1px solid rgba(45,212,191,0.3); color: var(--color-acid)">
            ✓ Mensaje enviado. Te respondo pronto.
          </div>
          <div id="form-error" class="hidden rounded-xl px-4 py-3 text-sm"
               style="background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3); color: #f87171">
            Hubo un error al enviar. Intenta de nuevo o escríbeme directo.
          </div>

          <button type="submit" id="submit-btn" class="btn-primary w-full justify-center text-sm">
            <span id="btn-text">Enviar mensaje</span>
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
            </svg>
          </button>
        </form>
      </div>

      <!-- Contact info -->
      <div class="md:col-span-2 space-y-5">
        <!-- Direct contact -->
        <div class="card-glass p-5 rounded-2xl space-y-4">
          <h3 class="font-display font-semibold text-white text-sm">Contacto directo</h3>

          <a href="mailto:hola@jairyara.dev" class="flex items-center gap-3 text-slate-soft hover:text-white transition-colors group">
            <div class="w-9 h-9 rounded-lg bg-acid/10 border border-acid/15 flex items-center justify-center text-acid shrink-0">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
            <div>
              <div class="text-xs font-mono text-white/30 mb-0.5">Email</div>
              <div class="text-sm group-hover:text-acid transition-colors">hola@jairyara.dev</div>
            </div>
          </a>

          <a href="https://wa.me/573000000000" target="_blank" class="flex items-center gap-3 text-slate-soft hover:text-white transition-colors group">
            <div class="w-9 h-9 rounded-lg bg-emerald-500/10 border border-emerald-500/15 flex items-center justify-center text-emerald-400 shrink-0">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
            </div>
            <div>
              <div class="text-xs font-mono text-white/30 mb-0.5">WhatsApp</div>
              <div class="text-sm group-hover:text-emerald-400 transition-colors">Escríbeme</div>
            </div>
          </a>
        </div>

        <!-- Availability -->
        <div class="card-glass p-5 rounded-2xl space-y-3">
          <div class="flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
            <span class="text-white text-sm font-semibold">Disponible</span>
          </div>
          <p class="text-slate-soft text-xs leading-relaxed">
            Acepto 2–3 proyectos nuevos por mes. Respondo en menos de 24 horas, 
            generalmente el mismo día.
          </p>
          <div class="pt-2 border-t border-white/5 space-y-1">
            <div class="flex justify-between text-xs">
              <span class="text-white/30 font-mono">Zona horaria</span>
              <span class="text-white">UTC-5 (Bogotá)</span>
            </div>
            <div class="flex justify-between text-xs">
              <span class="text-white/30 font-mono">Remoto</span>
              <span class="text-acid">✓ Sí, internacional</span>
            </div>
          </div>
        </div>

        <!-- Social -->
        <div class="card-glass p-5 rounded-2xl">
          <h3 class="font-display font-semibold text-white text-sm mb-3">Redes</h3>
          <div class="flex gap-3">
            {[
              { label: 'GitHub', href: 'https://github.com/tu-usuario', icon: 'GH' },
              { label: 'LinkedIn', href: 'https://linkedin.com/in/tu-usuario', icon: 'in' },
            ].map(social => (
              <a 
                href={social.href} target="_blank" rel="noopener noreferrer"
                class="flex-1 py-2 rounded-lg bg-white/5 hover:bg-acid/10 border border-white/10 hover:border-acid/30 text-center text-xs font-mono text-slate-soft hover:text-acid transition-all"
              >
                {social.label}
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const btn = document.getElementById('submit-btn') as HTMLButtonElement;
  const btnText = document.getElementById('btn-text') as HTMLSpanElement;
  const success = document.getElementById('form-success') as HTMLDivElement;
  const error = document.getElementById('form-error') as HTMLDivElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    btn.disabled = true;
    btnText.textContent = 'Enviando...';
    success.classList.add('hidden');
    error.classList.add('hidden');

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        body: new FormData(form),
      });

      if (res.ok) {
        success.classList.remove('hidden');
        form.reset();
      } else {
        error.classList.remove('hidden');
      }
    } catch {
      error.classList.remove('hidden');
    } finally {
      btn.disabled = false;
      btnText.textContent = 'Enviar mensaje';
    }
  });
</script>
