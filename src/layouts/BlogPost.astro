---
import Layout from './Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags?: string[];
  readTime?: string;
}

const { title, description, pubDate, tags = [], readTime } = Astro.props;
const formattedDate = new Date(pubDate).toLocaleDateString('es-CO', {
  year: 'numeric', month: 'long', day: 'numeric'
});
---

<Layout title={`${title} — Jair Yara`} description={description}>
  <Nav />

  <main class="pt-28 pb-20">
    <article class="max-w-2xl mx-auto px-6">
      <header class="mb-12">
        <div class="flex flex-wrap gap-2 mb-6">
          {tags.map(tag => (
              <span class="tag">{tag}</span>
          ))}
        </div>
        <h1 class="font-display text-3xl md:text-4xl font-bold text-white leading-tight mb-4"
            style="font-family: var(--font-display)">
          {title}
        </h1>
        <p class="text-lg mb-6" style="color: var(--color-slate-soft)">{description}</p>
        <div class="flex items-center gap-4 text-sm border-t border-white/5 pt-4"
             style="font-family: var(--font-mono); color: var(--color-slate-soft)">
          <time>{formattedDate}</time>
          {readTime && <>
            <span style="color: rgba(255,255,255,0.2)">·</span>
            <span>{readTime}</span>
          </>}
        </div>
      </header>

      <div class="prose prose-invert prose-lg max-w-none">
        <slot />
      </div>

      <div class="mt-16 pt-8 border-t border-white/5">
        <a href="/blog" class="btn-ghost text-sm">← Volver al Blog</a>
      </div>
    </article>
  </main>

  <Footer />
</Layout>