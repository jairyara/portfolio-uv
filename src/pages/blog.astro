---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Layout 
  title="Blog — Jair Yara"
  description="Artículos sobre desarrollo web, ciberseguridad, SaaS y emprendimiento tech desde Bogotá."
>
  <Nav />

  <main class="pt-28 pb-20 px-6">
    <div class="max-w-4xl mx-auto">
      <!-- Header -->
      <div class="mb-14">
        <span class="section-label">Blog</span>
        <h1 class="font-display text-5xl md:text-6xl font-extrabold text-white mt-2 leading-tight">
          Notas técnicas<br /><span class="text-acid">& aprendizajes</span>
        </h1>
        <p class="text-slate-soft mt-4 max-w-xl">
          Escribo sobre lo que aprendo: seguridad ofensiva, desarrollo web, productos indie 
          y lecciones de construir para el mercado colombiano.
        </p>
      </div>

      <!-- Posts list -->
      <div class="space-y-4">
        {posts.map(post => {
          const date = new Date(post.data.pubDate).toLocaleDateString('es-CO', {
            year: 'numeric', month: 'long', day: 'numeric'
          });
          return (

              <a href={`/blog/${post.id.replace(/\.mdx?$/, '')}/`}
          class="card-glass p-6 rounded-2xl flex flex-col md:flex-row md:items-center gap-4 hover:border-white/10 transition-all duration-300 group block mb-4"
              >
              <div class="flex-1">
                <div class="flex flex-wrap gap-2 mb-3">
                  {post.data.tags?.slice(0, 3).map((tag: string) => (
                      <span class="tag">{tag}</span>
                  ))}
                </div>
                <h2 class="font-display font-bold text-lg text-white mb-1.5"
                    style="font-family: var(--font-display)">
                  {post.data.title}
                </h2>
                <p class="text-sm leading-relaxed" style="color: var(--color-slate-soft)">
                  {post.data.description}
                </p>
              </div>
              <div class="flex flex-col items-end shrink-0 gap-2">
                <time class="text-xs" style="font-family: var(--font-mono); color: rgba(255,255,255,0.3)">
                  {date}
                </time>
                <svg class="w-4 h-4 opacity-0 group-hover:opacity-100 transition-all"
                     style="color: var(--color-acid)"
                     fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                        d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                </svg>
              </div>
          </a>
          );
        })}
    </div>
    </div>
  </main>

  <Footer />
</Layout>
